<%- include("head.partial.ejs") %>

<main>
  <h1>Edit Save: <%= id %></h1>
  <% if (!save) { %>
    <p>Save not found.</p>
    <p><a href="/saves/">Back to saves</a></p>
  <% } else { %>
    <form action="/saves/<%= id %>/edit" method="POST">
      <div>
        <label for="name">Name</label>
        <input id="name" name="name" value="<%= save.name %>" required minlength="1" />
      </div>
      <div>
        <label for="difficulty">Difficulty</label>
        <select name="difficulty" id="difficulty" required>
          <option value="easy" <%= save.data[0].difficulty === 'easy' ? 'selected' : '' %>>easy</option>
          <option value="medium" <%= save.data[0].difficulty === 'medium' ? 'selected' : '' %>>medium</option>
          <option value="hard" <%= save.data[0].difficulty === 'hard' ? 'selected' : '' %>>hard</option>
        </select>
      </div>
      <div>
        <label for="progress">Progress</label>
        <input id="progress" name="progress" value="<%= save.data[1].progress %>" />
      </div>
      <div>
        <button type="submit">Save changes</button>
        <a href="/saves/">Cancel</a>
      </div>
    </form>
  <% } %>
</main>

<%- include("foot.partial.ejs") %>
